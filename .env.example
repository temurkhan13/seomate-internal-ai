# SEOMATE environment variables. Copy to .env and fill in.
# Never commit .env — only .env.example is tracked.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=seomate
POSTGRES_PASSWORD=seomate_dev
POSTGRES_DB=seomate
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://seomate:seomate_dev@localhost:5433/seomate

# ─── Auditor / API runtime ───────────────────────────────────────────────────
SEOMATE_LOG_LEVEL=INFO
SEOMATE_DATA_DIR=./auditor/data

# ─── DataForSEO (the primary external SEO API) ───────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Google APIs (owner-granted, only required for the pilot site) ───────────
# Service-account JSON file paths (gitignored)
GSC_SERVICE_ACCOUNT_FILE=./credentials/gsc.json
GBP_SERVICE_ACCOUNT_FILE=./credentials/gbp.json
GBP_ACCOUNT_ID=

# Public Google APIs (just need an API key)
GOOGLE_KG_API_KEY=
GOOGLE_PSI_API_KEY=

# ─── LLM providers (used in H1c and beyond) ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── AI search engines (used in H1d and beyond) ──────────────────────────────
PERPLEXITY_API_KEY=

# ─── Off-page / entity ecosystem (H1d) ───────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
LISTEN_NOTES_API_KEY=
YOUTUBE_API_KEY=

# ─── Web UI → API (consumed by Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Search Console + Analytics (GA4) + Business Profile (owner data:
# P5 local, GSC rankings/sitemap, GA4 engagement). OAuth, not an API key.
# ONE consent grant covers all three — the refresh token is scope-bound, so
# scopes webmasters.readonly + analytics.readonly are granted together (see
# docs/google-oauth-setup.md). When unset, the dependent variables stay
# unmeasurable (no guessing). Mint the token with:
#   python scripts/get_google_refresh_token.py --client-secret-file <downloaded.json>
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# GA4 Analytics Data API property (numeric, format properties/NNNNNNNNN).
# Find it in GA4 Admin → Property Settings, or run the helper above which
# lists every property the consenting account can see.
GA4_PROPERTY_ID=
